" shen.a) (stoutput)) (shen.evaluate-lineread Y NewHistory V9608))))) ((and (cons? V9606) (and (= () (tl V9606)) (and (cons? V9607) (and (shen.+string? (hd V9607)) (= "%" (hdstr (hd V9607))))))) (let Read (hd (read-from-string (tlstr (hd V9607)))) (let Peek (shen.peek-history Read (tlstr (hd V9607)) (tl V9607)) (let NewHistory (set shen.*history* (tl V9607)) (abort))))) ((and (cons? V9606) (and (= () (tl V9606)) (and (cons? V9607) (and (shen.+string? (hd V9607)) (= "!" (hdstr (hd V9607))))))) (let Read (hd (read-from-string (tlstr (hd V9607)))) (let Match (shen.use-history Read (tlstr (hd V9607)) (tl V9607)) (let Print (pr (shen.app Match "
