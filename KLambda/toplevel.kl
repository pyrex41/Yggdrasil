" (shen.app (nth (+ 1 V9612) (reverse V9614)) "" shen.a)) (stoutput)) (if (or (= V9613 "") (symbol? V9612)) (shen.recursive-string-match 0 V9613 (reverse V9614)) (simple-error "% expects a number or a symbol
"))))

